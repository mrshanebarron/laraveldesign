{
    "name": "mrshanebarron/laraveldesign",
    "description": "WordPress-like CMS for Laravel - manage pages, posts, menus, and media",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cms", "wordpress", "blog", "pages", "posts"],
    "authors": [
        {
            "name": "Shane Barron",
            "email": "mrshanebarron@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "filament/filament": "^3.0",
        "livewire/livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "MrShaneBarron\\LaravelDesign\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MrShaneBarron\\LaravelDesign\\LaravelDesignServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
